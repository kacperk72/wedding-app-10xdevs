# OpenRouter API key — one key, many models.
# Local: copy to .env (gitignored). CI: store as GitHub Actions secret OPENROUTER_API_KEY.
OPENROUTER_API_KEY=

# Optional: override the review model (vendor/model on OpenRouter).
# Defaults to anthropic/claude-haiku-4.5 (cheap, runs per PR).
# REVIEW_MODEL=anthropic/claude-haiku-4.5
