+// Lista kontraktów wraz z danymi kontrahentów (scope: bieżące wesele).
+router.get("/with-vendors", async (req, res, next) => {
+  try {
+    const { data: contracts } = await supabase
+      .from("contracts")
+      .select("*")
+      .eq("wedding_id", req.weddingId);
+
+    const vendorIds = [...new Set(contracts.map((c) => c.vendor_id).filter(Boolean))];
+    const { data: vendors } = await supabase
+      .from("vendors")
+      .select("*")
+      .eq("wedding_id", req.weddingId)
+      .in("id", vendorIds);
+
+    const byId = new Map(vendors.map((v) => [v.id, v]));
+    res.json(
+      contracts.map((c) => ({ ...mapContract(c), vendor: byId.get(c.vendor_id) ?? null })),
+    );
+  } catch (err) {
+    next(err);
+  }
+});
