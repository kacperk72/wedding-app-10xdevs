@@ -0,0 +1,28 @@
+import test from "node:test";
+import assert from "node:assert/strict";
+import { makeApp } from "./helpers/http-app.js";
+import { seedWedding } from "./helpers/e2e-seed.js";
+
+test("GET /with-vendors zwraca kontrakty z kontrahentami tylko z tego wesela", async () => {
+  const { app, weddingId, token } = await makeApp();
+  await seedWedding(weddingId, { vendors: 1, contracts: 1 });
+
+  const res = await app
+    .get(`/api/weddings/${weddingId}/contracts/with-vendors`)
+    .set("Authorization", `Bearer ${token}`);
+
+  assert.equal(res.status, 200);
+  assert.equal(res.body.length, 1);
+  assert.ok(res.body[0].vendor, "kontrakt ma dołączonego kontrahenta");
+});
+
+test("GET /with-vendors nie przecieka kontrahentów z innego wesela", async () => {
+  const { app, weddingId, token } = await makeApp();
+  const otherWedding = await seedWedding("other", { vendors: 1 });
+
+  const res = await app
+    .get(`/api/weddings/${weddingId}/contracts/with-vendors`)
+    .set("Authorization", `Bearer ${token}`);
+
+  assert.equal(res.status, 200);
+  assert.deepEqual(res.body, []);
+});
