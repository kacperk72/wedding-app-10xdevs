+// Nowy endpoint: lista kontraktów wraz z danymi kontrahentów.
+router.get("/with-vendors", async (req, res, next) => {
+  try {
+    const { data: contracts } = await supabase
+      .from("contracts")
+      .select("*")
+      .eq("wedding_id", req.weddingId);
+
+    // Dociągamy wszystkich kontrahentów i mapujemy po id.
+    const { data: vendors } = await supabase.from("vendors").select("*");
+    const byId = new Map(vendors.map((v) => [v.id, v]));
+
+    res.json(
+      contracts.map((c) => ({ ...mapContract(c), vendor: byId.get(c.vendor_id) })),
+    );
+  } catch (err) {
+    next(err);
+  }
+});
