{
  "name": "@wedding-planner/code-reviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI code-review agent (Vercel AI SDK + OpenRouter) for wedding-app-10xdevs PRs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "review": "tsx --env-file-if-exists=.env src/review.ts",
    "eval": "promptfoo eval",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "promptfoo": "^0.118.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
