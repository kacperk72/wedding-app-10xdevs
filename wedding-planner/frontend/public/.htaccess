RewriteEngine On
RewriteBase /

# 1. Nie przepisuj ruchu kierowanego do API — Hostinger Passenger routuje to do Node.js app.
#    Bez tego wyjątku Apache łapie /api/* zanim Passenger zdąży zareagować i wrzuca index.html.
RewriteRule ^api/ - [L]

# 2. Wymuś HTTPS — refresh cookie z SSO chodzi SameSite=None; Secure.
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. SPA fallback dla Angular routera.
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# 4. Cache: pliki z hashem cache'ujemy długo, index.html nigdy.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>